[package]
name = "uacpi-bindings"
version = "0.1.2"
edition = "2024"
license = "MIT"
description = "A bindgen generated set of bindings to the uACPI library."
repository = "https://github.com/AlulaOneshot/uacpi-bindings"
categories = ["api-bindings", "no-std::no-alloc", "hardware-support"]
keywords = ["acpi", "uacpi", "bindings", "hardware"]
links = "uacpi"

[build-dependencies]
cc = "1.2.37"
bindgen = "0.72.1"